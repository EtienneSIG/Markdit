{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markdit",
  "version": "0.4.0",
  "identifier": "app.markdit.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Markdit",
        "width": 1100,
        "height": 760,
        "minWidth": 640,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https://graph.microsoft.com https://login.microsoftonline.com",
      "capabilities": []
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": ["icons/icon.ico"],
    "publisher": "Etienne Sigwald",
    "license": "MIT",
    "copyright": "Copyright (c) 2026 Etienne Sigwald",
    "windows": {
      "allowDowngrades": false,
      "wix": {
        "language": ["en-US", "fr-FR"]
      },
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English", "French"],
        "displayLanguageSelector": true
      },
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "pubkey": "",
      "endpoints": ["https://releases.markdit.app/{{target}}/{{arch}}/{{current_version}}"]
    }
  }
}
